{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "rm -rf / *": "deny",
      "rm -rf /home/*": "deny",
      "rm -rf ~/*": "deny",
      "sudo *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "pip install *": "deny",
      "pip3 install *": "deny",
      "apt *": "deny",
      "chmod 777 *": "deny",
      "mkfs *": "deny",
      "dd *": "deny",
      "fdisk *": "deny",
      "mount *": "deny",
      "umount *": "deny"
    },
    "external_directory": {
      "*": "deny"
    },
    "webfetch": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "task": {
      "*": "deny"
    }
  }
}
